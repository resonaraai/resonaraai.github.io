[Unit]
Description=Resonara local audio server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/resonara-web-app/server
EnvironmentFile=/opt/resonara-web-app/server/.env
ExecStart=/opt/resonara-web-app/server/.venv/bin/uvicorn app:app --host 127.0.0.1 --port 8787 --proxy-headers
Restart=on-failure
RestartSec=5
User=resonara
Group=resonara
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/tmp

[Install]
WantedBy=multi-user.target
