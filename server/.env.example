# Copy this to .env and adjust paths.
# Generate a long random token, for example: openssl rand -hex 32
SERVER_API_TOKEN=replace-with-long-random-token
REQUEST_LIMIT_PER_MINUTE=30
MAX_AUDIO_BYTES=20971520

# For GitHub Pages + Tailscale Funnel you can leave CORS open during testing
# because the X-Client-Token still protects the API. For production, set your Pages origin.
# Example: CORS_ORIGINS=https://deinuser.github.io
CORS_ORIGINS=*

# STT: whisper.cpp. This is required for /api/transcribe.
FFMPEG_BIN=ffmpeg
WHISPER_CPP_BIN=/opt/whisper.cpp/build/bin/whisper-cli
WHISPER_MODEL=/opt/whisper.cpp/models/ggml-base.bin
# Optional, e.g. more threads: WHISPER_EXTRA_ARGS=-t 8
WHISPER_EXTRA_ARGS=

# TTS: Piper. This is optional but recommended for /api/speak.
PIPER_BIN=piper
PIPER_MODEL=/opt/piper-voices/de_DE-thorsten-medium.onnx
# Optional speaker ID for multi-speaker voices.
PIPER_SPEAKER=
PIPER_EXTRA_ARGS=

# Legacy mode only. The Web-App-first app does not need Ollama.
ENABLE_LEGACY_LLM=false
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TEMPERATURE=0.35
OLLAMA_NUM_PREDICT=220
